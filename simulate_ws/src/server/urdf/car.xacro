<?xml version="1.0"?>

<robot name="erp42" xmlns:xacro="http://www.ros.org/wiki/xacro">
  
    <xacro:arg name="car_name" default="car1"/>

    <xacro:property name="mass" value="200.0"/>
    <xacro:property name="wheelbase" value="1.0"/>
    <xacro:property name="wheel_mass" value="5.0"/>

    <link name="$(arg car_name)/chassis">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <mesh filename="file://$(find server)/mesh/body.stl" scale="1.0 1.0 1.0"/>
            </geometry>
            <material name="whiteblue">
                <color rgba="0.3 0.3 0.8 1"/>
            </material>    
        </visual>
        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <mesh filename="file://$(find server)/mesh/body.stl" scale="1.0 1.0 1.0"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <mass value="${mass}"/>
            <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
        </inertial>
        
    </link>

    <link name="$(arg car_name)/rear_left_wheel">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <mesh filename="file://$(find server)/mesh/left.stl" scale="1.0 1.0 1.0"/>
            </geometry>
            <material name="black">
                <color rgba="0.1 0.1 0.1 1"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="1.5708 0.0 0.0"/>
            <geometry>
                <cylinder radius="0.27" length="0.197"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <mass value="${wheel_mass}"/>
            <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
        </inertial>
        
    </link>

    <link name="$(arg car_name)/rear_right_wheel">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <mesh filename="file://$(find server)/mesh/right.stl" scale="1.0 1.0 1.0"/>
            </geometry>
            <material name="black">
                <color rgba="0.1 0.1 0.1 1"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="1.5708 0.0 0.0"/>
            <geometry>
                <cylinder radius="0.27" length="0.197"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <mass value="${wheel_mass}"/>
            <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
        </inertial>
        
    </link>

    <link name="$(arg car_name)/front_left_wheel">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <mesh filename="file://$(find server)/mesh/left.stl" scale="1.0 1.0 1.0"/>
            </geometry>
            <material name="black">
                <color rgba="0.1 0.1 0.1 1"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="1.5708 0.0 0.0"/>
            <geometry>
                <cylinder radius="0.27" length="0.197"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <mass value="${wheel_mass}"/>
            <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
        </inertial>
        
    </link>

    <link name="$(arg car_name)/front_right_wheel">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <mesh filename="file://$(find server)/mesh/right.stl" scale="1.0 1.0 1.0"/>
            </geometry>
            <material name="black">
                <color rgba="0.1 0.1 0.1 1"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="1.5708 0.0 0.0"/>
            <geometry>
                <cylinder radius="0.27" length="0.197"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <mass value="${wheel_mass}"/>
            <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
        </inertial>
        
    </link>
    
    <link name="$(arg car_name)/front_left_steer_link">
        <inertial><mass value="0.1"/><inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/></inertial>
    </link>
    <link name="$(arg car_name)/front_right_steer_link">
        <inertial><mass value="0.1"/><inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/></inertial>
    </link>

    <joint name="$(arg car_name)/rear_left_joint" type="continuous">
        <parent link="$(arg car_name)/chassis"/>
        <child link="$(arg car_name)/rear_left_wheel"/>
        <origin xyz="-0.485 0.50013 0.26999" rpy="0.0 0.0 0.0"/>
        <axis xyz= "0 1 0"/>
    </joint>

    <joint name="$(arg car_name)/rear_right_joint" type="continuous">
        <parent link="$(arg car_name)/chassis"/>
        <child link="$(arg car_name)/rear_right_wheel"/>
        <origin xyz="-0.485 -0.50013 0.26999" rpy="0.0 0.0 0.0"/>
        <axis xyz= "0 1 0"/>
    </joint>

    <joint name="$(arg car_name)/front_left_steer_joint" type="revolute">
        <parent link="$(arg car_name)/chassis"/>
        <child link="$(arg car_name)/front_left_steer_link"/>
        <origin xyz="0.532 0.50013 0.26999" rpy="0.0 0.0 0.0"/>
        <axis xyz= "0 0 1"/>
        <limit lower="-0.6" upper="0.6" effort="10.0" velocity="1.0"/>
    </joint>

    <joint name="$(arg car_name)/front_left_joint" type="continuous">
        <parent link="$(arg car_name)/front_left_steer_link"/>
        <child link="$(arg car_name)/front_left_wheel"/>
        <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        <axis xyz= "0 1 0"/>
    </joint>

    <joint name="$(arg car_name)/front_right_steer_joint" type="revolute">
        <parent link="$(arg car_name)/chassis"/>
        <child link="$(arg car_name)/front_right_steer_link"/>
        <origin xyz="0.532 -0.50013 0.26999" rpy="0.0 0.0 0.0"/>
        <axis xyz= "0 0 1"/>
        <limit lower="-0.6" upper="0.6" effort="10.0" velocity="1.0"/>
    </joint>

    <joint name="$(arg car_name)/front_right_joint" type="continuous">
        <parent link="$(arg car_name)/front_right_steer_link"/>
        <child link="$(arg car_name)/front_right_wheel"/>
        <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        <axis xyz= "0 1 0"/>
    </joint>

    <link name="$(arg car_name)/lidar_link">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="0.05165" length="0.0717"/>
            </geometry>
            <material name="Gray">
                <color rgba="0.169 0.169 0.169 1"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="0.05165" length="0.0717"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.83"/>
            <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
        </inertial>
    </link>

    <joint name="$(arg car_name)/lidar_joint" type="fixed">
        <parent link="$(arg car_name)/chassis"/>
        <child link="$(arg car_name)/lidar_link"/>
        <origin xyz="-0.3 0.0 0.95" rpy="0.0 0.0 0.0"/>
    </joint>

    <link name="$(arg car_name)/livox_lidar_link">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="0.115 0.077 0.0841"/>
            </geometry>
            <material name="Gray">
                <color rgba="0.169 0.169 0.169 1"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="0.115 0.077 0.0841"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="1.18"/>
            <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
        </inertial>
    </link>
    
    <joint name="$(arg car_name)/livox_lidar_joint" type="fixed">
        <parent link="$(arg car_name)/chassis"/>
        <child link="$(arg car_name)/livox_lidar_link"/>
        <origin xyz="0.055 0.0 0.74" rpy="0.0 0.0524 0.0"/>
    </joint>

    <link name="$(arg car_name)/camera_link">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="0.025 0.02 0.025"/>
            </geometry>
            <material name="Black">
                <color rgba="0.0 0.0 0.0 1.0"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="0.025 0.02 0.025"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.05"/>
            <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
        </inertial>
    </link>

    <joint name="$(arg car_name)/camera_joint" type="fixed">
        <parent link="$(arg car_name)/chassis"/>
        <child link="$(arg car_name)/camera_link"/>
        <origin xyz="0.1 0.0 0.68" rpy="0.0 0.0 0.0"/>
    </joint>

    <link name="$(arg car_name)/gps_link">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="0.025" length="0.03"/>
            </geometry>
            <material name="Red">
                <color rgba="1.0 0.0 0.0 1.0"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="0.025" length="0.03"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.02"/>
            <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
        </inertial>
    </link>

    <joint name="$(arg car_name)/gps_joint" type="fixed">
        <parent link="$(arg car_name)/chassis"/>
        <child link="$(arg car_name)/gps_link"/>
        <origin xyz="-0.65 0.0 0.6" rpy="0.0 0.0 0.0"/>
    </joint>

    <gazebo>
        <plugin name="gz::sim::systems::AckermannSteering" filename="gz-sim-ackermann-steering-system">
            <left_steering_joint>$(arg car_name)/front_left_steer_joint</left_steering_joint>
            <right_steering_joint>$(arg car_name)/front_right_steer_joint</right_steering_joint>
            <left_joint>$(arg car_name)/rear_left_joint</left_joint>
            <right_joint>$(arg car_name)/rear_right_joint</right_joint>
            
            <wheel_base>${wheelbase}</wheel_base>
            <wheel_separation>0.2</wheel_separation>
            <wheel_radius>0.27</wheel_radius>

            <steering_limit>0.3491</steering_limit>
            <odom_publish_frequency>50.0</odom_publish_frequency>

            <topic>/$(arg car_name)/cmd_vel</topic>
            <odom_topic>/$(arg car_name)/odom</odom_topic>
            <frame_id>$(arg car_name)/odom</frame_id>
            <child_frame_id>$(arg car_name)/chassis</child_frame_id>
        </plugin>

        <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
            <topic>/$(arg car_name)/joint_states</topic>
            <joint_name>$(arg car_name)/front_left_steer_joint</joint_name>
            <joint_name>$(arg car_name)/front_right_steer_joint</joint_name>
            <joint_name>$(arg car_name)/rear_left_joint</joint_name>
            <joint_name>$(arg car_name)/rear_right_joint</joint_name>
            <joint_name>$(arg car_name)/front_left_joint</joint_name>
            <joint_name>$(arg car_name)/front_right_joint</joint_name>
        </plugin>
    </gazebo>
    
    <gazebo reference="$(arg car_name)/lidar_link">
        <sensor name="velodyne_lidar" type="gpu_lidar">
            <always_on>true</always_on>
            <visualize>false</visualize>
            <update_rate>20.0</update_rate>
            <topic>/$(arg car_name)/scan</topic>
            <gz_frame_id>$(arg car_name)/lidar_link</gz_frame_id>
            <lidar>
                <scan>
                    <horizontal>
                        <samples>1800</samples>
                        <resolution>1.0</resolution>
                        <min_angle>-3.14159</min_angle>
                        <max_angle>3.14159</max_angle>
                    </horizontal>
                    <vertical>
                        <samples>16</samples>
                        <resolution>1.0</resolution>
                        <min_angle>-0.2618</min_angle>
                        <max_angle>0.2618</max_angle>
                    </vertical>
                </scan>
                <range>
                    <min>0.5</min>
                    <max>100.0</max>
                    <resolution>0.002</resolution>
                </range>
            </lidar>
        </sensor>
    </gazebo>

    <gazebo reference="$(arg car_name)/livox_lidar_link">
        <sensor name="livox_lidar" type="gpu_lidar">
            <always_on>true</always_on>
            <visualize>false</visualize>
            <update_rate>10.0</update_rate>
            <topic>/$(arg car_name)/livox</topic>
            <gz_frame_id>$(arg car_name)/livox_lidar_link</gz_frame_id>
            <lidar>
                <scan>
                    <horizontal>
                        <samples>400</samples>
                        <resolution>1.0</resolution>
                        <min_angle>-0.713</min_angle>
                        <max_angle>0.713</max_angle>
                    </horizontal>
                    <vertical>
                        <samples>120</samples>
                        <resolution>1.0</resolution>
                        <min_angle>-0.219</min_angle>
                        <max_angle>0.219</max_angle>
                    </vertical>
                </scan>
                <range>
                    <min>0.5</min>
                    <max>260.0</max>
                    <resolution>0.002</resolution>
                </range>
            </lidar>
        </sensor>
    </gazebo>

    <gazebo reference="$(arg car_name)/camera_link">
        <sensor name="camera" type="camera">
            <always_on>true</always_on>
            <visualize>false</visualize>
            <update_rate>20.0</update_rate>
            <topic>/$(arg car_name)/camera/image_raw</topic>
            <gz_frame_id>$(arg car_name)/camera_link</gz_frame_id>
            <camera>
                <horizontal_fov>1.047</horizontal_fov>
                <image>
                    <width>1280</width>
                    <height>720</height>
                    <format>R8G8B8</format>
                </image>
                <clip>
                    <near>0.1</near>
                    <far>100.0</far>
                </clip>
            </camera>
        </sensor>
    </gazebo>

    <gazebo reference="$(arg car_name)/gps_link">
        <sensor name="navsat" type="navsat">
            <always_on>true</always_on>
            <visualize>false</visualize>
            <update_rate>10.0</update_rate>
            <topic>/$(arg car_name)/gps/fix</topic>
            <gz_frame_id>$(arg car_name)/gps_link</gz_frame_id>
            <navsat>
                <position_sensing>
                    <horizontal>
                        <noise type="gaussian">
                            <mean>0.0</mean>
                            <stddev>0.0</stddev>
                        </noise>
                    </horizontal>
                    <vertical>
                        <noise type="gaussian">
                            <mean>0.0</mean>
                            <stddev>0.0</stddev>
                        </noise>
                    </vertical>
                </position_sensing>
            </navsat>
        </sensor>
    </gazebo>

</robot>