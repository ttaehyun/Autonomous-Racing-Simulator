<?xml version="1.0"?>

<robot name="erp42" xmlns:xacro="http://www.ros.org/wiki/xacro">
  
    <xacro:arg name="car_name" default="car1"/>

    <xacro:property name="mass" value="10.0"/>
    <xacro:property name="wheelbase" value="0.3"/>
    <xacro:property name="track_width" value="0.2"/>
    <xacro:property name="wheel_radius" value="0.05"/>
    <xacro:property name="wheel_mass" value="1.0"/>

    <link name="chassis">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <mesh filename="/home/th/Autonomous-Racing-Simulator/simulate_ws/src/server/mesh/body.stl" scale="1.0 1.0 1.0"/>
            </geometry>
            <material name="whiteblue">
                <color rgba="0.3 0.3 0.8 1"/>
            </material>    
        </visual>
        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <mesh filename="/home/th/Autonomous-Racing-Simulator/simulate_ws/src/server/mesh/body.stl" scale="1.0 1.0 1.0"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <mass value="${mass}"/>
            <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
        </inertial>
        
    </link>

    <link name="rear_left_wheel">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <mesh filename="/home/th/Autonomous-Racing-Simulator/simulate_ws/src/server/mesh/left.stl" scale="1.0 1.0 1.0"/>
            </geometry>
            <material name="black">
                <color rgba="0.1 0.1 0.1 1"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="1.5708 0.0 0.0"/>
            <geometry>
                <cylinder radius="0.27" length="0.197"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <mass value="${wheel_mass}"/>
            <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
        </inertial>
        
    </link>

    <link name="rear_right_wheel">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <mesh filename="/home/th/Autonomous-Racing-Simulator/simulate_ws/src/server/mesh/right.stl" scale="1.0 1.0 1.0"/>
            </geometry>
            <material name="black">
                <color rgba="0.1 0.1 0.1 1"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="1.5708 0.0 0.0"/>
            <geometry>
                <cylinder radius="0.27" length="0.197"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <mass value="${wheel_mass}"/>
            <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
        </inertial>
        
    </link>

    <link name="front_left_wheel">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <mesh filename="/home/th/Autonomous-Racing-Simulator/simulate_ws/src/server/mesh/left.stl" scale="1.0 1.0 1.0"/>
            </geometry>
            <material name="black">
                <color rgba="0.1 0.1 0.1 1"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="1.5708 0.0 0.0"/>
            <geometry>
                <cylinder radius="0.27" length="0.197"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <mass value="${wheel_mass}"/>
            <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
        </inertial>
        
    </link>

    <link name="front_right_wheel">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <mesh filename="/home/th/Autonomous-Racing-Simulator/simulate_ws/src/server/mesh/right.stl" scale="1.0 1.0 1.0"/>
            </geometry>
            <material name="black">
                <color rgba="0.1 0.1 0.1 1"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="1.5708 0.0 0.0"/>
            <geometry>
                <cylinder radius="0.27" length="0.197"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <mass value="${wheel_mass}"/>
            <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
        </inertial>
        
    </link>
    
    <link name="front_left_steer_link">
        <inertial><mass value="0.1"/><inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/></inertial>
    </link>
    <link name="front_right_steer_link">
        <inertial><mass value="0.1"/><inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/></inertial>
    </link>

    <link name="lidar_link">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="0.05165" length="0.0717"/>
            </geometry>
            <material name="Gray">
                <color rgba="0.169 0.169 0.169 1"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="0.05165" length="0.0717"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.83"/>
            <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
        </inertial>
    </link>

    <joint name="rear_left_joint" type="continuous">
        <parent link="chassis"/>
        <child link="rear_left_wheel"/>
        <origin xyz="-0.485 0.50013 0.26999" rpy="0.0 0.0 0.0"/>
        <axis xyz= "0 1 0"/>
    </joint>

    <joint name="rear_right_joint" type="continuous">
        <parent link="chassis"/>
        <child link="rear_right_wheel"/>
        <origin xyz="-0.485 -0.50013 0.26999" rpy="0.0 0.0 0.0"/>
        <axis xyz= "0 1 0"/>
    </joint>

    <joint name="front_left_steer_joint" type="revolute">
        <parent link="chassis"/>
        <child link="front_left_steer_link"/>
        <origin xyz="0.532 0.50013 0.26999" rpy="0.0 0.0 0.0"/>
        <axis xyz= "0 0 1"/>
        <limit lower="-0.6" upper="0.6" effort="10.0" velocity="1.0"/>
    </joint>

    <joint name="front_left_joint" type="continuous">
        <parent link="front_left_steer_link"/>
        <child link="front_left_wheel"/>
        <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        <axis xyz= "0 1 0"/>
    </joint>

    <joint name="front_right_steer_joint" type="revolute">
        <parent link="chassis"/>
        <child link="front_right_steer_link"/>
        <origin xyz="0.532 -0.50013 0.26999" rpy="0.0 0.0 0.0"/>
        <axis xyz= "0 0 1"/>
        <limit lower="-0.6" upper="0.6" effort="10.0" velocity="1.0"/>
    </joint>

    <joint name="front_right_joint" type="continuous">
        <parent link="front_right_steer_link"/>
        <child link="front_right_wheel"/>
        <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        <axis xyz= "0 1 0"/>
    </joint>

    <joint name="lidar_joint" type="fixed">
        <parent link="chassis"/>
        <child link="lidar_link"/>
        <origin xyz="-0.3 0.0 0.95" rpy="0.0 0.0 0.0"/>
    </joint>

    <link name="camera_link">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="0.025 0.02 0.025"/>
            </geometry>
            <material name="Black">
                <color rgba="0.0 0.0 0.0 1.0"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="0.025 0.02 0.025"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.05"/>
            <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
        </inertial>
    </link>

    <joint name="camera_joint" type="fixed">
        <parent link="chassis"/>
        <child link="camera_link"/>
        <origin xyz="0.1 0.0 0.68" rpy="0.0 0.0 0.0"/>
    </joint>

    <link name="gps_link">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="0.025" length="0.03"/>
            </geometry>
            <material name="Red">
                <color rgba="1.0 0.0 0.0 1.0"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="0.025" length="0.03"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.02"/>
            <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
        </inertial>
    </link>

    <joint name="gps_joint" type="fixed">
        <parent link="chassis"/>
        <child link="gps_link"/>f
        <origin xyz="-0.65 0.0 0.6" rpy="0.0 0.0 0.0"/>
    </joint>
    
    <gazebo>
        <plugin name="gz::sim::systems::AckermannSteering" filename="gz-sim-ackermann-steering-system">
            <left_steering_joint>front_left_steer_joint</left_steering_joint>
            <right_steering_joint>front_right_steer_joint</right_steering_joint>
            <left_joint>rear_left_joint</left_joint>
            <right_joint>rear_right_joint</right_joint>
            
            <wheel_base>${wheelbase}</wheel_base>
            <wheel_separation>0.2</wheel_separation>
            <wheel_radius>0.27</wheel_radius>

            <steering_limit>0.6</steering_limit>
            <odom_publish_frequency>50.0</odom_publish_frequency>

            <topic>cmd_vel</topic>
            <odom_topic>/odom</odom_topic>
            <frame_id>odom</frame_id>
            <child_frame_id>chassis</child_frame_id>
        </plugin>

        <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
            <topic>joint_states</topic>
            <joint_name>front_left_steer_joint</joint_name>
            <joint_name>front_right_steer_joint</joint_name>
            <joint_name>rear_left_joint</joint_name>
            <joint_name>rear_right_joint</joint_name>
            <joint_name>front_left_joint</joint_name>
            <joint_name>front_right_joint</joint_name>
        </plugin>
    </gazebo>
    
</robot>